# Unique name prefix for all resources (required)
name_prefix = "my-org-adv"

# AWS region (optional, defaults to us-east-1)
region = "us-east-1"

# CloudTrail S3 bucket suffix (will be prefixed with name_prefix)
cloudtrail_bucket_name = "cloudtrail-logs"

# GuardDuty findings bucket suffix (will be prefixed with name_prefix)
guardduty_findings_bucket_name = "guardduty-findings"

# Security Hub configuration
enable_pci_standard = true

# Macie configuration
macie_s3_buckets_to_scan = [
  "my-sensitive-data-bucket",
  "my-pii-data-bucket"
]

# Budget configuration
budget_limit_usd = 2000
budget_alert_subscribers = [
  "admin@example.com",
  "finance@example.com",
  "security@example.com"
]

# Tags to apply to all resources (optional)
tags = {
  Environment        = "production"
  Owner              = "platform-team"
  Project            = "secure-landing-zone"
  CostCenter         = "IT-001"
  Compliance         = "SOC2"
  DataClassification = "confidential"
}
